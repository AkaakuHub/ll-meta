<ui:FluentWindow
  x:Class="OpenKikaiSan.App.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="clr-namespace:OpenKikaiSan.App.Controls"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  mc:Ignorable="d"
  Title="OpenKikaiSan"
  Height="860"
  Width="1380"
  MinHeight="720"
  MinWidth="1120"
  WindowStartupLocation="CenterScreen"
  Background="Transparent"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="Mica"
  WindowCornerPreference="Round"
>
  <Window.Resources>
    <SolidColorBrush x:Key="BrandBrush" Color="#68BE8D" />
    <SolidColorBrush x:Key="BrandTintBrush" Color="#1468BE8D" />
    <SolidColorBrush x:Key="ShellBorderBrush" Color="#14000000" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#CCF7F7F7" />
    <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#EAFBFBFB" />
    <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#B5FFFFFF" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1B1B" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5E5E5E" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C" />

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MetricTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardStyle" TargetType="ui:Card">
      <Setter Property="Margin" Value="0,0,0,20" />
      <Setter Property="Padding" Value="24" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="InfoPanelStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar
      Grid.Row="0"
      Title="OpenKikaiSan"
      Icon="{ui:ImageIcon 'pack://application:,,,/Assets/icon.ico'}"
      ShowMinimize="True"
      ShowMaximize="True"
      ShowClose="True"
      Background="Transparent"
    />

    <ScrollViewer
      Grid.Row="1"
      VerticalScrollBarVisibility="Auto"
      HorizontalScrollBarVisibility="Disabled"
      Padding="24,20,24,12"
      Background="Transparent"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="360" />
          <ColumnDefinition Width="24" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <ui:Card Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Text="Controls" Style="{StaticResource SectionTitleStyle}" />
              <TextBlock
                Margin="0,6,0,18"
                Text="{Binding StatusMessage}"
                Style="{StaticResource BodyTextStyle}"
              />

              <Border
                Style="{StaticResource InfoPanelStyle}"
                Background="{StaticResource BrandTintBrush}"
              >
                <TextBlock
                  Text="{Binding ActiveInputSource}"
                  Style="{StaticResource MetricTextStyle}"
                />
              </Border>

              <ui:ToggleSwitch
                Content="Enable Keyboard Debug Input"
                IsChecked="{Binding IsKeyboardDebugMode}"
                Margin="0,0,0,18"
              />

              <TextBlock
                Text="Input TCP Port"
                Style="{StaticResource BodyTextStyle}"
                Margin="0,0,0,8"
              />

              <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="132" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                  Grid.Column="0"
                  Text="{Binding WindowsInputTcpPort, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="Port"
                  VerticalContentAlignment="Center"
                />

                <ui:Button
                  Grid.Column="2"
                  Content="Save Input TCP Port"
                  Command="{Binding ApplyInputTcpPortCommand}"
                  Appearance="Primary"
                />
              </Grid>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button
                  Grid.Column="0"
                  Content="Reinitialize OpenXR"
                  Command="{Binding ReinitializeOpenXrCommand}"
                  Appearance="Primary"
                />

                <ui:Button
                  Grid.Column="2"
                  Content="Select Window / Monitor"
                  Command="{Binding SelectCaptureTargetCommand}"
                  Appearance="Secondary"
                />
              </Grid>
            </StackPanel>
          </ui:Card>

          <ui:Card Style="{StaticResource CardStyle}" Margin="0,0,0,0">
            <StackPanel>
              <TextBlock Text="Keyboard Mapping" Style="{StaticResource SectionTitleStyle}" />
              <TextBlock
                Margin="0,10,0,0"
                Text="Left stick: WASD | Right stick: IJKL | Buttons: 1(X) 2(Y) 3(A) 4(B) | Trigger/Grip: Q E U O | Stick click: LeftShift RightShift | HMD yaw/pitch/roll: Arrow + PageUp/PageDown | HMD position: F/H(X) T/G(Y) R/V(Z)"
                Style="{StaticResource BodyTextStyle}"
              />
            </StackPanel>
          </ui:Card>
        </StackPanel>

        <StackPanel Grid.Column="2">
          <ui:Card Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Text="Overview" Style="{StaticResource PageTitleStyle}" />
              <TextBlock
                Margin="0,8,0,20"
                Text="{Binding OpenXrInputStatus}"
                Style="{StaticResource BodyTextStyle}"
              />

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoPanelStyle}">
                  <TextBlock
                    Text="{Binding OpenXrInputStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource InfoPanelStyle}">
                  <TextBlock
                    Text="{Binding BridgeStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoPanelStyle}">
                  <TextBlock
                    Text="{Binding VideoStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
                <Border
                  Grid.Row="1"
                  Grid.Column="2"
                  Style="{StaticResource InfoPanelStyle}"
                  Margin="0,0,0,0"
                >
                  <TextBlock
                    Text="{Binding CaptureStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
              </Grid>
            </StackPanel>
          </ui:Card>

          <ui:Card Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Text="Capture And Render" Style="{StaticResource SectionTitleStyle}" />
              <TextBlock
                Margin="0,6,0,18"
                Text="{Binding VideoRenderConfigStatus}"
                Style="{StaticResource BodyTextStyle}"
              />

              <Border Style="{StaticResource InfoPanelStyle}">
                <TextBlock
                  Text="{Binding CaptureStatus}"
                  Style="{StaticResource MetricTextStyle}"
                />
              </Border>

              <Border Style="{StaticResource InfoPanelStyle}">
                <TextBlock
                  Text="{Binding VideoRenderConfigStatus}"
                  Style="{StaticResource MetricTextStyle}"
                />
              </Border>

              <Border Style="{StaticResource InfoPanelStyle}" Margin="0">
                <TextBlock
                  Text="{Binding VideoRenderErrorStatus}"
                  Foreground="{StaticResource ErrorBrush}"
                  TextWrapping="Wrap"
                />
              </Border>
            </StackPanel>
          </ui:Card>

          <ui:Card Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
              <TextBlock Text="Tracking" Style="{StaticResource SectionTitleStyle}" />
              <TextBlock
                Margin="0,6,0,18"
                Text="{Binding ActiveInputSource}"
                Style="{StaticResource BodyTextStyle}"
              />

              <TabControl Margin="0,16,0,0">
                <TabItem Header="3D View">
                  <controls:OpenXrSceneView
                    Height="360"
                    State="{Binding CurrentOpenXrState}"
                    StatusText="{Binding OpenXrInputStatus}"
                  />
                </TabItem>

                <TabItem Header="Text">
                  <StackPanel Margin="12">
                    <Border Style="{StaticResource InfoPanelStyle}">
                      <TextBlock
                        Text="{Binding HmdPoseState}"
                        Style="{StaticResource MetricTextStyle}"
                      />
                    </Border>

                    <Border Style="{StaticResource InfoPanelStyle}">
                      <TextBlock
                        Text="{Binding LeftControllerState}"
                        Style="{StaticResource MetricTextStyle}"
                      />
                    </Border>

                    <Border Style="{StaticResource InfoPanelStyle}" Margin="0">
                      <TextBlock
                        Text="{Binding RightControllerState}"
                        Style="{StaticResource MetricTextStyle}"
                      />
                    </Border>
                  </StackPanel>
                </TabItem>
              </TabControl>
            </StackPanel>
          </ui:Card>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Margin="24,0,24,20"
      Padding="16,10"
      Background="{StaticResource SurfaceStrongBrush}"
      BorderBrush="{StaticResource ShellBorderBrush}"
      BorderThickness="1"
      CornerRadius="10"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
          Text="OpenKikaiSan"
          Foreground="{StaticResource TextSecondaryBrush}"
          VerticalAlignment="Center"
        />

        <TextBlock
          Grid.Column="1"
          Text="{Binding StatusMessage}"
          Foreground="{StaticResource TextSecondaryBrush}"
          VerticalAlignment="Center"
        />
      </Grid>
    </Border>
  </Grid>
</ui:FluentWindow>
