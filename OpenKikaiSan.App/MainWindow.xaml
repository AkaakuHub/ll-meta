<ui:FluentWindow
  x:Class="OpenKikaiSan.App.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="clr-namespace:OpenKikaiSan.App.Controls"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  mc:Ignorable="d"
  Title="OpenKikaiSan"
  Height="860"
  Width="1380"
  MinHeight="720"
  MinWidth="1120"
  WindowStartupLocation="CenterScreen"
  Background="Transparent"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="Mica"
  WindowCornerPreference="Round"
>
  <Window.Resources>
    <SolidColorBrush x:Key="BrandBrush" Color="#68BE8D" />
    <SolidColorBrush x:Key="BrandTintBrush" Color="#1468BE8D" />
    <SolidColorBrush x:Key="ShellBorderBrush" Color="#14000000" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#CCF7F7F7" />
    <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#EAFBFBFB" />
    <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#B5FFFFFF" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1B1B" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5E5E5E" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C" />

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MetricTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardStyle" TargetType="ui:Card">
      <Setter Property="Margin" Value="0,0,0,20" />
      <Setter Property="Padding" Value="24" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="InfoPanelStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style
      x:Key="CompactInfoPanelStyle"
      TargetType="Border"
      BasedOn="{StaticResource InfoPanelStyle}"
    >
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="CompactCardStyle" TargetType="ui:Card" BasedOn="{StaticResource CardStyle}">
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="ControlCardStyle" TargetType="ui:Card" BasedOn="{StaticResource CardStyle}">
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="ControlPanelStyle" TargetType="Border" BasedOn="{StaticResource InfoPanelStyle}">
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ControlLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MappingGroupTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MappingTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ui:TitleBar
      Grid.Row="0"
      Title="OpenKikaiSan"
      Icon="{ui:ImageIcon 'pack://application:,,,/Assets/icon.ico'}"
      ShowMinimize="True"
      ShowMaximize="True"
      ShowClose="True"
      Background="Transparent"
    />

    <ScrollViewer
      Grid.Row="1"
      VerticalScrollBarVisibility="Auto"
      HorizontalScrollBarVisibility="Disabled"
      Padding="24,16,24,12"
      Background="Transparent"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="360" />
          <ColumnDefinition Width="24" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <ui:Card Style="{StaticResource ControlCardStyle}">
            <StackPanel>
              <Border Style="{StaticResource ControlPanelStyle}">
                <ui:ToggleSwitch
                  Content="Enable Keyboard Debug Input"
                  IsChecked="{Binding IsKeyboardDebugMode}"
                />
              </Border>

              <Border Style="{StaticResource ControlPanelStyle}" Margin="0,0,0,14">
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                      Text="Input TCP Port"
                      Style="{StaticResource ControlLabelStyle}"
                      Margin="0"
                    />
                    <TextBlock
                      Grid.Column="1"
                      Text="{Binding ActiveWindowsInputTcpPort}"
                      Style="{StaticResource BodyTextStyle}"
                      VerticalAlignment="Center"
                    />
                  </Grid>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBox
                      Grid.Column="0"
                      Text="{Binding WindowsInputTcpPort, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="Port"
                      VerticalContentAlignment="Center"
                      Height="42"
                    />

                    <ui:Button
                      Grid.Column="2"
                      Content="Save Port"
                      Command="{Binding ApplyInputTcpPortCommand}"
                      Appearance="Primary"
                    />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource ControlPanelStyle}" Margin="0,0,0,14">
                <StackPanel>
                  <TextBlock Text="Log Level" Style="{StaticResource ControlLabelStyle}" />

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="132" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                      Grid.Column="0"
                      ItemsSource="{Binding AvailableLogLevels}"
                      SelectedItem="{Binding LogLevel}"
                      Height="42"
                    />

                    <ui:Button
                      Grid.Column="2"
                      Content="Save Log"
                      Command="{Binding ApplyLogLevelCommand}"
                      Appearance="Secondary"
                    />
                  </Grid>
                </StackPanel>
              </Border>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="144" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button
                  Grid.Column="0"
                  Content="Refresh OpenXR"
                  Command="{Binding ReinitializeOpenXrCommand}"
                  Appearance="Primary"
                />

                <ui:Button
                  Grid.Column="2"
                  Content="Select Capture Source"
                  Command="{Binding SelectCaptureTargetCommand}"
                  Appearance="Caution"
                  Foreground="White"
                  PressedForeground="White"
                  HorizontalAlignment="Right"
                />
              </Grid>
            </StackPanel>
          </ui:Card>
        </StackPanel>

        <Grid Grid.Column="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <ui:Card Grid.Row="0" Style="{StaticResource CompactCardStyle}">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                  <TextBlock
                    Text="{Binding OpenXrInputStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                  <TextBlock
                    Text="{Binding BridgeStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>
              </Grid>
            </StackPanel>
          </ui:Card>

          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="0.92*" />
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="1.08*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Style="{StaticResource CompactCardStyle}" Margin="0">
              <StackPanel>
                <TextBlock
                  Text="Capture And Render"
                  Style="{StaticResource SectionTitleStyle}"
                  Margin="0,0,0,12"
                />

                <Border Style="{StaticResource CompactInfoPanelStyle}">
                  <TextBlock
                    Text="{Binding ActiveInputSource}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>

                <Border Style="{StaticResource CompactInfoPanelStyle}">
                  <TextBlock
                    Text="{Binding CaptureStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>

                <Border Style="{StaticResource CompactInfoPanelStyle}">
                  <TextBlock
                    Text="{Binding VideoRenderConfigStatus}"
                    Style="{StaticResource MetricTextStyle}"
                  />
                </Border>

                <Border Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                  <TextBlock
                    Text="{Binding VideoRenderErrorStatus}"
                    Foreground="{StaticResource ErrorBrush}"
                    TextWrapping="Wrap"
                  />
                </Border>
              </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="2" Style="{StaticResource CompactCardStyle}" Margin="0">
              <StackPanel>
                <TextBlock
                  Text="Tracking"
                  Style="{StaticResource SectionTitleStyle}"
                  Margin="0,0,0,12"
                />

                <TabControl Margin="0,4,0,0">
                  <TabItem Header="3D View">
                    <controls:OpenXrSceneView Height="300" State="{Binding CurrentOpenXrState}" />
                  </TabItem>

                  <TabItem Header="Text">
                    <StackPanel Margin="10">
                      <Border Style="{StaticResource CompactInfoPanelStyle}">
                        <TextBlock
                          Text="{Binding HmdPoseState}"
                          Style="{StaticResource MetricTextStyle}"
                        />
                      </Border>

                      <Border Style="{StaticResource CompactInfoPanelStyle}">
                        <TextBlock
                          Text="{Binding LeftControllerState}"
                          Style="{StaticResource MetricTextStyle}"
                        />
                      </Border>

                      <Border Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                        <TextBlock
                          Text="{Binding RightControllerState}"
                          Style="{StaticResource MetricTextStyle}"
                        />
                      </Border>
                    </StackPanel>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </ui:Card>
          </Grid>

          <ui:Card Grid.Row="2" Style="{StaticResource CompactCardStyle}" Margin="0,16,0,0">
            <StackPanel>
              <TextBlock
                Text="Keyboard Mapping"
                Style="{StaticResource SectionTitleStyle}"
                Margin="0,0,0,12"
              />

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="16" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <Border Style="{StaticResource CompactInfoPanelStyle}">
                    <StackPanel>
                      <TextBlock Text="Sticks" Style="{StaticResource MappingGroupTitleStyle}" />
                      <TextBlock
                        Text="Left stick: WASD"
                        Style="{StaticResource MappingTextStyle}"
                      />
                      <TextBlock
                        Margin="0,4,0,0"
                        Text="Right stick: IJKL"
                        Style="{StaticResource MappingTextStyle}"
                      />
                    </StackPanel>
                  </Border>

                  <Border Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                    <StackPanel>
                      <TextBlock
                        Text="Face Buttons"
                        Style="{StaticResource MappingGroupTitleStyle}"
                      />
                      <TextBlock
                        Text="X: 1    Y: 2    A: 3    B: 4"
                        Style="{StaticResource MappingTextStyle}"
                      />
                      <TextBlock
                        Margin="0,4,0,0"
                        Text="Stick click: LeftShift / RightShift"
                        Style="{StaticResource MappingTextStyle}"
                      />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                  <Border Style="{StaticResource CompactInfoPanelStyle}">
                    <StackPanel>
                      <TextBlock
                        Text="Trigger And Grip"
                        Style="{StaticResource MappingGroupTitleStyle}"
                      />
                      <TextBlock
                        Text="Left trigger / grip: Q / E"
                        Style="{StaticResource MappingTextStyle}"
                      />
                      <TextBlock
                        Margin="0,4,0,0"
                        Text="Right trigger / grip: U / O"
                        Style="{StaticResource MappingTextStyle}"
                      />
                    </StackPanel>
                  </Border>

                  <Border Style="{StaticResource CompactInfoPanelStyle}" Margin="0">
                    <StackPanel>
                      <TextBlock Text="HMD" Style="{StaticResource MappingGroupTitleStyle}" />
                      <TextBlock
                        Text="Yaw and pitch: Arrow keys"
                        Style="{StaticResource MappingTextStyle}"
                      />
                      <TextBlock
                        Margin="0,4,0,0"
                        Text="Roll: PageUp / PageDown"
                        Style="{StaticResource MappingTextStyle}"
                      />
                      <TextBlock
                        Margin="0,4,0,0"
                        Text="Position X / Y / Z: F-H / T-G / R-V"
                        Style="{StaticResource MappingTextStyle}"
                      />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>
            </StackPanel>
          </ui:Card>
        </Grid>
      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Margin="24,0,24,20"
      Padding="16,10"
      Background="{StaticResource SurfaceStrongBrush}"
      BorderBrush="{StaticResource ShellBorderBrush}"
      BorderThickness="1"
      CornerRadius="10"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
          Text="OpenKikaiSan"
          Foreground="{StaticResource TextSecondaryBrush}"
          VerticalAlignment="Center"
        />

        <TextBlock
          Grid.Column="1"
          Text="{Binding StatusMessage}"
          Foreground="{StaticResource TextSecondaryBrush}"
          VerticalAlignment="Center"
        />
      </Grid>
    </Border>
  </Grid>
</ui:FluentWindow>
